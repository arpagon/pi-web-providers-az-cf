{
  "name": "pi-web-providers-az-cf",
  "version": "0.1.2",
  "description": "Minimal Pi web providers extension for OpenAI-compatible/Azure Responses API and Cloudflare Browser Rendering markdown.",
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "FORK.md",
    "example-config.json",
    "scripts/e2e-pi-smoke.mjs"
  ],
  "keywords": [
    "pi-package",
    "pi-extension",
    "coding-agent",
    "web-search",
    "web-contents",
    "web-answer",
    "web-research",
    "azure-openai",
    "openai",
    "cloudflare"
  ],
  "author": "Arpagon",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arpagon/pi-web-providers-az-cf.git"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "pi": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "scripts": {
    "build": "rm -rf dist && esbuild src/index.ts --bundle --format=esm --platform=node --outfile=dist/index.js --external:@earendil-works/pi-coding-agent --external:@earendil-works/pi-tui --external:typebox",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e:pi": "npm run build && node scripts/e2e-pi-smoke.mjs ./dist/index.js",
    "prepare": "npm run build",
    "prepack": "npm run build"
  },
  "dependencies": {},
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.74.0",
    "@earendil-works/pi-tui": "^0.74.0",
    "@types/node": "^25.6.0",
    "esbuild": "^0.28.0",
    "typebox": "^1.1.34",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  }
}
